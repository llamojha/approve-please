{
  "name": "approve-please",
  "version": "1.0.0",
  "private": true,
  "description": "Approve Please — a Papers, Please-style pull-request review game",
  "scripts": {
    "predev": "npm run generate:templates",
    "dev": "next dev",
    "prebuild": "npm run generate:templates",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
